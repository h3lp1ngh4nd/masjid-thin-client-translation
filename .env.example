# VPS relay server
HOST=127.0.0.1
PORT=8080
RELAY_TOKEN=change-me-long-random-token

# Optional
MAX_CAPTIONS=100
# Websocket ping interval; missed pong = reap dead viewer/uplink sockets.
HEARTBEAT_MS=30000
VOLG_HEADER_TEXT=live
VOLG_EMPTY_TEXT=Wachten op vertaling...
VOLG_FOOTER_TEXT=Live vertaling is in BETA. Er kunnen fouten voorkomen.
